APP_ENV=local
SECRET_KEY=dev-secret
JWT_SECRET_KEY=dev-jwt-secret-key-32bytes-minimum-2026
DATABASE_URL=sqlite:///nle_reviewer.db
GROQ_API_KEY=
GROQ_MODEL=llama3-70b-8192
SUPABASE_URL=
SUPABASE_KEY=
CORS_ORIGINS=*
AUTO_SEED_ON_BOOT=1

# Production (recommended for Supabase pooler):
